<?xml version="1.0"?>

<!-- prius.urdf.xacro
    Toyota Prius (Gen3) model for Gazebo simulation.
    Lengths are measured in meters, angles are measured in radians, and masses are
    measured in kilograms.
-->

<robot name="prius" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- Mesh path prefix: resolves to absolute path for Gazebo -->
  <xacro:property name="mesh_path" value="file://$(find vehicle_gazebo)/models/meshes"/>

  <!-- ============================================================
       VEHICLE PROPERTIES
       ============================================================ -->

  <!-- Vehicle geometry: dimensions and wheelbase -->
  <xacro:property name="wheelbase"         value="2.55"/>
  <xacro:property name="track_front"       value="1.534"/>
  <xacro:property name="track_rear"        value="1.520"/>

  <!-- Wheel properties -->
  <xacro:property name="wheel_radius"      value="0.31265"/>
  <xacro:property name="wheel_mass"        value="11.0"/>

  <!-- Suspension properties: spring travel and shock characteristics -->
  <xacro:property name="wheel_travel"      value="0.10"/>
  <xacro:property name="shock_z_offset"    value="0.20"/>
  <xacro:property name="shock_eff_limit"   value="8000.0"/>
  <xacro:property name="shock_vel_limit"   value="1000.0"/>

  <!-- Steering properties: maximum steering angle and servo limits -->
  <xacro:property name="max_steer"         value="0.6458"/>
  <xacro:property name="steer_eff_limit"   value="10000.0"/>
  <xacro:property name="steer_vel_limit"   value="1000.0"/>

  <!-- Rear axle actuation limits -->
  <xacro:property name="axle_eff_limit"    value="859.4"/>
  <xacro:property name="axle_vel_limit"    value="121.5"/>

  <!-- ============================================================
       VISUAL MATERIALS
       ============================================================ -->
  <material name="chassis_mat"><color rgba="0.2 0.2 0.6 1"/></material>
  <material name="wheel_mat">  <color rgba="0.1 0.1 0.1 1"/></material>
  <material name="imu_mat">    <color rgba="0.0 1.0 0.0 1"/></material>
  <material name="gps_mat">    <color rgba="1.0 1.0 1.0 1"/></material>
  <material name="cam_mat">    <color rgba="0.6 0.0 0.0 1"/></material>

  <!-- ============================================================
       NULL INERTIA MACRO (for kinematic links)
       ============================================================ -->
  <xacro:macro name="null_inertial">
    <inertial>
      <mass value="0.001"/>
      <inertia ixx="0.001" ixy="0" ixz="0"
               iyy="0.001" iyz="0" izz="0.001"/>
    </inertial>
  </xacro:macro>

  <!-- ============================================================
       BASE LINK (coordinate system origin)
       ============================================================ -->
  <link name="base_link">
    <inertial>
      <mass value="1"/>
      <inertia ixx="0.001" ixy="0" ixz="0"
               iyy="0.001" iyz="0" izz="0.001"/>
    </inertial>
    <visual>
      <geometry><box size="0.01 0.01 0.01"/></geometry>
      <material name="chassis_mat"/>
    </visual>
  </link>

  <!-- ============================================================
       CHASSIS (vehicle body)
       ============================================================ -->
  <joint name="base_link_to_chassis" type="fixed">
    <parent link="base_link"/>
    <child  link="chassis"/>
    <origin xyz="1.45 0 ${-shock_z_offset}" rpy="0 0 1.5707963"/>
  </joint>

  <link name="chassis">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="${mesh_path}/hybrid_body.obj" scale="0.01 0.01 0.01"/>
      </geometry>
    </visual>

    <!-- Compound collision geometry representing vehicle body -->
    <collision name="chassis_col">
      <origin xyz="0.0 0.05 0.625"/>
      <geometry><box size="1.7526 2.1 0.95"/></geometry>
    </collision>
    <collision name="front_bumper_col">
      <origin xyz="0.0 -2.0 0.458488"/>
      <geometry><box size="1.337282 0.48 0.566691"/></geometry>
    </collision>
    <collision name="hood_col">
      <origin xyz="0.0 -1.900842 0.676305" rpy="0.341247 0 0"/>
      <geometry><box size="1.597968 0.493107 0.265468"/></geometry>
    </collision>
    <collision name="windshield_col">
      <origin xyz="0.0 -0.875105 1.032268" rpy="0.335476 0 0"/>
      <geometry><box size="1.168381 1.654253 0.272347"/></geometry>
    </collision>
    <collision name="top_front_col">
      <origin xyz="0.0 0.161236 1.386042" rpy="0.135030 0 0"/>
      <geometry><box size="1.279154 0.625988 0.171868"/></geometry>
    </collision>
    <collision name="top_rear_col">
      <origin xyz="0.0 0.817696 1.360069" rpy="-0.068997 0 0"/>
      <geometry><box size="1.285130 0.771189 0.226557"/></geometry>
    </collision>
    <collision name="rear_window_col">
      <origin xyz="0.0 1.640531 1.175126" rpy="-0.262017 0 0"/>
      <geometry><box size="1.267845 1.116344 0.244286"/></geometry>
    </collision>
    <collision name="trunk_col">
      <origin xyz="0.0 1.637059 0.888180"/>
      <geometry><box size="1.788064 1.138988 0.482746"/></geometry>
    </collision>
    <collision name="back_bumper_col">
      <origin xyz="0.0 2.054454 0.577870"/>
      <geometry><box size="1.781650 0.512093 0.581427"/></geometry>
    </collision>

    <!-- Inertia properties: curb mass of Prius Gen3 -->
    <inertial>
      <mass value="1326.0"/>
      <origin xyz="0 0 0.48" rpy="0 0 1.5708"/>
      <inertia ixx="2581.13354740" ixy="0" ixz="0"
               iyy="591.30846112"  iyz="0"
               izz="2681.95008628"/>
    </inertial>
  </link>

  <gazebo reference="chassis">
    <self_collide>false</self_collide>
  </gazebo>

  <!-- ============================================================
       LINEAR SUSPENSION MACRO
       Structure for each wheel:
         chassis → prismatic joint (shock) → suspension_link
                   → revolute joint (steering, front only)
                   → continuous joint (wheel rotation)

       Prismatic joint limits:
         lower = -wheel_travel/2  (compression)
         upper = +wheel_travel/2  (extension)
  ============================================================ -->

  <!-- Front wheel suspension, steering, and wheel assembly -->
  <xacro:macro name="front_wheel" params="prefix x y">

    <!-- Suspension link: pivots at shock attachment point -->
    <link name="${prefix}_front_suspension_link">
      <xacro:null_inertial/>
    </link>

    <!-- Vertical shock absorber joint (linear spring-damper) -->
    <joint name="${prefix}_front_shock" type="prismatic">
      <parent link="chassis"/>
      <child  link="${prefix}_front_suspension_link"/>
      <origin xyz="${x} ${y} ${shock_z_offset}"/>
      <axis xyz="0 0 1"/>
      <limit lower="${-wheel_travel / 2}" upper="${wheel_travel / 2}"
             effort="${shock_eff_limit}" velocity="${shock_vel_limit}"/>
      <dynamics damping="5000.0" friction="100.0"/>
    </joint>

    <!-- Steering link: rotates for directional control -->
    <link name="${prefix}_front_steer_link">
      <xacro:null_inertial/>
    </link>

    <!-- Steering joint: controls wheel direction (rotation around Z axis) -->
    <joint name="${prefix}_steering_joint" type="revolute">
      <parent link="${prefix}_front_suspension_link"/>
      <child  link="${prefix}_front_steer_link"/>
      <origin xyz="0 0 0"/>
      <axis xyz="0 0 1"/>
      <limit lower="${-max_steer}" upper="${max_steer}"
             effort="${steer_eff_limit}" velocity="${steer_vel_limit}"/>
      <dynamics damping="0.5" friction="0.01"/>
    </joint>

    <!-- Wheel: tire and hub assembly -->
    <link name="${prefix}_front_wheel">
      <visual>
        <geometry>
          <mesh filename="${mesh_path}/wheel.obj" scale="0.01 0.01 0.01"/>
        </geometry>
      </visual>
      <collision name="${prefix}_front_wheel_col">
        <geometry><sphere radius="${wheel_radius}"/></geometry>
      </collision>
      <inertial>
        <mass value="${wheel_mass}"/>
        <inertia ixx="0.58631238" ixy="0" ixz="0"
                 iyy="0.33552910" iyz="0"
                 izz="0.33552910"/>
      </inertial>
    </link>

    <!-- Wheel rotation joint: continuous rotation around X axis (forward motion) -->
    <joint name="${prefix}_front_axle" type="continuous">
      <parent link="${prefix}_front_steer_link"/>
      <child  link="${prefix}_front_wheel"/>
      <origin xyz="0 0 0"/>
      <axis xyz="1 0 0"/>
      <limit effort="${axle_eff_limit}" velocity="${axle_vel_limit}"/>
      <dynamics damping="0.5"/>
    </joint>

    <gazebo reference="${prefix}_front_wheel">
      <mu1>0.9</mu1><mu2>0.9</mu2>
      <minDepth>0.005</minDepth><kp>1e8</kp>
    </gazebo>
  </xacro:macro>

  <!-- Rear wheel suspension and wheel assembly (no steering capability) -->
  <xacro:macro name="rear_wheel" params="prefix x y">

    <link name="${prefix}_rear_suspension_link">
      <xacro:null_inertial/>
    </link>

    <joint name="${prefix}_rear_shock" type="prismatic">
      <parent link="chassis"/>
      <child  link="${prefix}_rear_suspension_link"/>
      <origin xyz="${x} ${y} ${shock_z_offset}"/>
      <axis xyz="0 0 1"/>
      <limit lower="${-wheel_travel / 2}" upper="${wheel_travel / 2}"
             effort="${shock_eff_limit}" velocity="${shock_vel_limit}"/>
      <dynamics damping="5000.0" friction="100.0"/>
    </joint>

    <link name="${prefix}_rear_wheel">
      <visual>
        <geometry>
          <mesh filename="${mesh_path}/wheel.obj" scale="0.01 0.01 0.01"/>
        </geometry>
      </visual>
      <collision name="${prefix}_rear_wheel_col">
        <geometry><sphere radius="${wheel_radius}"/></geometry>
      </collision>
      <inertial>
        <mass value="${wheel_mass}"/>
        <inertia ixx="0.58631238" ixy="0" ixz="0"
                 iyy="0.33552910" iyz="0"
                 izz="0.33552910"/>
      </inertial>
    </link>

    <joint name="${prefix}_rear_axle" type="continuous">
      <parent link="${prefix}_rear_suspension_link"/>
      <child  link="${prefix}_rear_wheel"/>
      <origin xyz="0 0 0"/>
      <axis xyz="1 0 0"/>
      <limit effort="${axle_eff_limit}" velocity="${axle_vel_limit}"/>
      <dynamics damping="0.5"/>
    </joint>

    <gazebo reference="${prefix}_rear_wheel">
      <mu1>0.9</mu1><mu2>0.9</mu2>
      <minDepth>0.005</minDepth><kp>1e8</kp>
    </gazebo>
  </xacro:macro>

  <!-- ============================================================
       WHEEL INSTANCES
       Wheel positions relative to chassis frame:
         Front left:   x= 0.767  y=-1.41
         Front right:  x=-0.767  y=-1.41
         Rear left:    x= 0.793  y= 1.45
         Rear right:   x=-0.793  y= 1.45
  ============================================================ -->
  <xacro:front_wheel prefix="left"  x="0.767"  y="-1.41"/>
  <xacro:front_wheel prefix="right" x="-0.767" y="-1.41"/>
  <xacro:rear_wheel  prefix="left"  x="0.793"  y="1.45"/>
  <xacro:rear_wheel  prefix="right" x="-0.793" y="1.45"/>

  <!-- ============================================================
       STEERING WHEEL (visual only)
       ============================================================ -->
  <link name="steering_wheel">
    <inertial>
      <mass value="1.0"/>
      <inertia ixx="0.14583300" ixy="0" ixz="0"
               iyy="0.14583300" iyz="0" izz="0.125"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="1.302101 0 0"/>
      <geometry>
        <mesh filename="${mesh_path}/steering_wheel.obj" scale="0.01 0.01 0.01"/>
      </geometry>
    </visual>
  </link>

  <joint name="steering_wheel_joint" type="continuous">
    <parent link="chassis"/>
    <child  link="steering_wheel"/>
    <origin xyz="0.357734 -0.627868 0.988243" rpy="-1.302101 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-7.85" upper="7.85" effort="1" velocity="100"/>
  </joint>

  <!-- ============================================================
       IMU (Inertial Measurement Unit) + MAGNETOMETER
       ============================================================ -->
  <joint name="imu_joint" type="fixed">
    <origin xyz="0 0 0.001" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child  link="imu_link"/>
  </joint>

  <link name="imu_link">
    <visual>
      <geometry><box size="0.030 0.025 0.002"/></geometry>
      <material name="imu_mat"/>
    </visual>
    <inertial>
      <mass value="0.001"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.0001" ixy="0" ixz="0"
               iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
  </link>

  <gazebo reference="imu_link">
    <sensor name="imu" type="imu">
      <always_on>true</always_on>
      <update_rate>200</update_rate>
      <visualize>true</visualize>
      <topic>imu</topic>
      <enable_metrics>true</enable_metrics>
      <gz_frame_id>imu_link</gz_frame_id>
      <imu>
        <angular_velocity>
          <x><noise type="gaussian"><mean>0.0</mean><stddev>0.0001</stddev>
            <bias_mean>0.0</bias_mean><bias_stddev>0.0</bias_stddev></noise></x>
          <y><noise type="gaussian"><mean>0.0</mean><stddev>0.0001</stddev>
            <bias_mean>0.0</bias_mean><bias_stddev>0.0</bias_stddev></noise></y>
          <z><noise type="gaussian"><mean>0.0</mean><stddev>0.0001</stddev>
            <bias_mean>0.0</bias_mean><bias_stddev>0.0</bias_stddev></noise></z>
        </angular_velocity>
        <linear_acceleration>
          <x><noise type="gaussian"><mean>0.0</mean><stddev>0.01</stddev>
            <bias_mean>0.0</bias_mean><bias_stddev>0.0</bias_stddev></noise></x>
          <y><noise type="gaussian"><mean>0.0</mean><stddev>0.01</stddev>
            <bias_mean>0.0</bias_mean><bias_stddev>0.0</bias_stddev></noise></y>
          <z><noise type="gaussian"><mean>0.0</mean><stddev>0.01</stddev>
            <bias_mean>0.0</bias_mean><bias_stddev>0.0</bias_stddev></noise></z>
        </linear_acceleration>
      </imu>
    </sensor>

    <sensor name="magnetometer" type="magnetometer">
      <always_on>true</always_on>
      <update_rate>50</update_rate>
      <visualize>false</visualize>
      <topic>magnetometer</topic>
      <enable_metrics>true</enable_metrics>
      <gz_frame_id>imu_link</gz_frame_id>
      <magnetometer>
        <x><noise type="gaussian"><mean>0.000000080</mean></noise></x>
        <y><noise type="gaussian"><mean>0.000000080</mean></noise></y>
        <z><noise type="gaussian"><mean>0.000000080</mean></noise></z>
      </magnetometer>
    </sensor>
  </gazebo>

  <!-- ============================================================
       GPS / NAVSAT (Global Navigation Satellite System)
       ============================================================ -->
  <joint name="gps_joint" type="fixed">
    <origin xyz="0 0 0.9" rpy="0 0 0"/>
    <parent link="imu_link"/>
    <child  link="gps_link"/>
  </joint>

  <link name="gps_link">
    <visual>
      <geometry><box size="0.015 0.015 0.006"/></geometry>
      <material name="gps_mat"/>
    </visual>
    <inertial>
      <mass value="0.01"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.0001" ixy="0" ixz="0"
               iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
  </link>

  <gazebo reference="gps_link">
    <sensor name="gps" type="navsat">
      <always_on>true</always_on>
      <update_rate>10</update_rate>
      <topic>gps/fix</topic>
      <gz_frame_id>gps_link</gz_frame_id>
      <navsat>
        <position_sensing>
          <horizontal>
            <noise type="gaussian">
              <mean>0.0</mean><stddev>0.00000018</stddev>
              <bias_mean>0.0</bias_mean>
            </noise>
          </horizontal>
          <vertical>
            <noise type="gaussian">
              <mean>0.0</mean><stddev>0.05</stddev>
              <bias_mean>0.0</bias_mean>
            </noise>
          </vertical>
        </position_sensing>
        <velocity_sensing>
          <horizontal>
            <noise type="gaussian"><mean>0.0</mean><stddev>0.01</stddev></noise>
          </horizontal>
          <vertical>
            <noise type="gaussian"><mean>0.0</mean><stddev>0.02</stddev></noise>
          </vertical>
        </velocity_sensing>
      </navsat>
    </sensor>
  </gazebo>

  <!-- ============================================================
     SEGMENTATION CAMERA (Dashcam position)
     ============================================================ -->
<joint name="seg_camera_joint" type="fixed">
  <origin xyz="0 -0.45 1.28" rpy="0 0.087 -1.5708"/>  <!-- pitch 5° lookdown -->
  <parent link="chassis"/>
  <child link="seg_camera_link"/>
</joint>

<link name="seg_camera_link">
  <visual>
    <geometry>
      <box size="0.02 0.04 0.03"/>
    </geometry>
    <material name="cam_mat"/>
  </visual>
  <inertial>
    <mass value="0.050"/>
    <origin xyz="0 0 0"/>
    <inertia ixx="0.0001" ixy="0" ixz="0"
             iyy="0.0001" iyz="0" izz="0.0001"/>
  </inertial>
</link>

<gazebo reference="seg_camera_link">
  <sensor name="segmentation_camera" type="segmentation">
    <topic>segmentation</topic>
    <camera>
      <segmentation_type>semantic</segmentation_type>
      <!-- FOV ~80° -->
      <horizontal_fov>1.3963</horizontal_fov>
      <image>
        <width>1280</width>
        <height>720</height>
      </image>
      <clip>
        <near>0.5</near>
        <far>80.0</far>  <!-- 80m -->
      </clip>
    </camera>
    <always_on>1</always_on>
    <update_rate>30</update_rate>
    <visualize>true</visualize>
  </sensor>
</gazebo>

  <!-- ============================================================
       GROUND TRUTH ODOMETRY
       ============================================================ -->
  <gazebo>
    <plugin filename="gz-sim-odometry-publisher-system"
            name="gz::sim::systems::OdometryPublisher">
      <odom_topic>ground_truth_odom</odom_topic>
      <odom_frame>odom</odom_frame>
      <robot_base_frame>base_link</robot_base_frame>
      <odom_publish_frequency>50</odom_publish_frequency>
    </plugin>
  </gazebo>

  <!-- ============================================================
       ROS2 CONTROL INTERFACE
       ============================================================ -->
  <ros2_control name="PriusGazeboSystem" type="system">
    <hardware>
      <plugin>gz_ros2_control/GazeboSimSystem</plugin>
    </hardware>

    <!-- Rear wheels: driven by velocity commands -->
    <joint name="left_rear_axle">
      <command_interface name="velocity"/>
      <state_interface   name="velocity"/>
      <state_interface   name="position"/>
    </joint>
    <joint name="right_rear_axle">
      <command_interface name="velocity"/>
      <state_interface   name="velocity"/>
      <state_interface   name="position"/>
    </joint>

    <!-- Front steering joints: controlled by position commands -->
    <joint name="left_steering_joint">
      <command_interface name="position"/>
      <state_interface   name="position"/>
    </joint>
    <joint name="right_steering_joint">
      <command_interface name="position"/>
      <state_interface   name="position"/>
    </joint>

    <!-- Front wheels: passive (state feedback only, no commands) -->
    <joint name="left_front_axle">
      <state_interface name="velocity"/>
      <state_interface name="position"/>
    </joint>
    <joint name="right_front_axle">
      <state_interface name="velocity"/>
      <state_interface name="position"/>
    </joint>
  </ros2_control>

  <gazebo>
    <plugin filename="gz_ros2_control-system"
            name="gz_ros2_control::GazeboSimROS2ControlPlugin">
      <parameters>$(find vehicle_gazebo)/config/ackermann_drive_controller.yaml</parameters>
    </plugin>
  </gazebo>

</robot>