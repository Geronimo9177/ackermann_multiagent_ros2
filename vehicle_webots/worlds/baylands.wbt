#VRML_SIM R2025a utf8

EXTERNPROTO "https://raw.githubusercontent.com/cyberbotics/webots/R2025a/projects/objects/backgrounds/protos/TexturedBackground.proto"
EXTERNPROTO "https://raw.githubusercontent.com/cyberbotics/webots/R2025a/projects/objects/backgrounds/protos/TexturedBackgroundLight.proto"
EXTERNPROTO "../models/tesla/TeslaModel3.proto"

WorldInfo {
  info ["Tesla vehicle simulation"]
  title "ROS2 simulation of the Tesla car"
  ERP 0.6
  basicTimeStep 10
  coordinateSystem "ENU"
  gpsCoordinateSystem "WGS84"
  gpsReference 43.3623 -8.4115 30
  lineScale 1
  contactProperties [
    ContactProperties {
      coulombFriction [
        8
      ]
      softCFM 1e-05
      bumpSound ""
      rollSound ""
      slideSound ""
    }
    ContactProperties {
      material2 "TeslaModel3Wheel"
      coulombFriction [
        8
      ]
      softCFM 1e-05
      bumpSound ""
      rollSound ""
      slideSound ""
    }
  ]
}

Viewpoint {
  orientation 0.0 0.4 -0.8 0.35
  position -20 8 6
  near 1
  follow "tesla"
  followSmoothness 0
}

TexturedBackground {
}

TexturedBackgroundLight {
}

# --- BASE ---
Solid {
  translation 0 0 -2.4
  name "baylands"

  children [
    CadShape {
      url ["media/baylandsV1.obj"]
      castShadows FALSE
    }
  ]

  boundingObject Mesh {
    url ["media/baylandsV1.obj"]
  }

  locked TRUE
}

# --- LEAVES / METAL (solo visual) ---
Solid {
  translation 0 0 -2.4
  name "leaves_metal"

  children [
    CadShape {
      url ["media/leaves_metal.obj"]
      castShadows FALSE
      isPickable FALSE
    }
  ]

  locked TRUE
}

# --- CURBS ---
Solid {
  translation 0 0 -2.4
  name "curbs"

  children [
    CadShape {
      url ["media/curb.obj"]
    }
  ]

  boundingObject Mesh {
    url ["media/curb.obj"]
  }

  locked TRUE
}

# --- POTHOLES ---
Solid {
  translation 0 0 -2.4
  name "potholes"

  children [
    CadShape {
      url ["media/potholes.obj"]
    }
  ]

  boundingObject Mesh {
    url ["media/potholes.obj"]
  }

  locked TRUE
}

# --- SPEEDBUMPS ---
Solid {
  translation 0 0 -2.4
  name "speedbumps"

  children [
    CadShape {
      url ["media/speedbumps.obj"]
    }
  ]

  boundingObject Mesh {
    url ["media/speedbumps.obj"]
  }

  locked TRUE
}


DEF tesla TeslaModel3 {
  translation 0 0 0.4
  rotation 0 0 1 0
  name "tesla"
  controller "<extern>"
  window "<none>"
  supervisor TRUE

  sensorsSlotFront [
    Camera {
          name "camera"
          translation -2.12 0 0.93
          fieldOfView 1
          width 360
          height 240
    }
  ]

  sensorsSlotCenter [
    InertialUnit { name "imu" }
    Gyro { name "gyro" }
    Accelerometer { name "accel" }
    Compass { name "mag" }
  ]

  sensorsSlotTop [
    GPS { 
      name "gps" 
      accuracy 1.5
    }
  ]
}